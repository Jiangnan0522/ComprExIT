# Copy to `.env` and edit, or export these in your shell before launching scripts.
# These are *stable* paths that rarely change once set. The model / checkpoint
# you operate on is passed as an argument to each script instead (see README).

# Root directory that holds the datasets (SlimPajama, MRQA, ...).
export DATA_DIR=/path/to/datasets

# Where training runs write checkpoints / logs (defaults to ./training_outputs).
export OUTPUT_DIR=./training_outputs

# Weights & Biases (optional). Either set the key here or run `wandb login`.
# export WANDB_API_KEY=your_key_here

# Multi-node training only (optional): the torchrun rendezvous host. Single-node
# runs leave this unset and the scripts fall back to the current hostname.
# export MASTER_ADDR=<head-node-hostname>
